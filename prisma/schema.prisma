generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String               @id @default(cuid())
  name          String
  email         String?              @unique
  phoneNumber   String?
  password      String
  tokenVersion  Int                  @default(0)
  avatarUrl     String?
  isAdmin       Boolean              @default(false)
  aiConfig      Json?
  aiChatMessages AiChatMessage[]
  memberships   OrganizationMember[]
  complaints    Complaint[]
  audioNotes    AudioNote[]
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
}

model AiChatMessage {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      String
  content   String
  bookId    String?
  model     String?
  provider  String?
  intent    String?
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

model Complaint {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject    String
  message    String
  status     String   @default("open")
  priority   String   @default("medium")
  category   String?
  assignedTo String?
  response   String?
  imageUrls  String[]
  videoUrls  String[]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@index([assignedTo])
}

model Organization {
  id                 String               @id @default(cuid())
  name               String
  isPersonal         Boolean              @default(false)
  inviteCode         String?              @unique
  imageUrl           String?
  categories         String[]             @default([])
  approvalPolicy     String               @default("GLOBALLY_ON")
  whitelistedUserIds String[]             @default([])
  members            OrganizationMember[]
  books              Book[]
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
}

model OrganizationMember {
  id             String       @id @default(cuid())
  userId         String
  organizationId String
  role           String       @default("member")
  status         String       @default("pending")
  permissions    String[]
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())

  @@unique([userId, organizationId])
  @@index([organizationId])
  @@index([status])
}

model Book {
  id             String       @id @default(cuid())
  name           String
  isDefault      Boolean      @default(false)
  isActive       Boolean      @default(true)
  balance        Float        @default(0)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  transactions   Transaction[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([organizationId])
  @@index([organizationId, isActive])
}

model Transaction {
  id                  String   @id @default(cuid())
  bookId              String
  amount              Float
  type                String
  note                String?
  category            String?
  contact             String?
  recipientUserId     String?
  recipientOrgId      String?
  linkedTransactionId String?
  orgFundId           String?
  fundType            String?
  fromLocation        String?
  toLocation          String?
  imageUrl            String?
  reconStatus         String   @default("approved")
  pendingAction       String?
  pendingData         Json?    @db.JsonB
  updateHistory       Json[]             @default([])
  dateTime            DateTime @default(now())
  status              String?
  createdById         String?
  counterProposedAmount Float?
  counterProposedBy     String?
  chainId             String?
  chainType           String?
  isLiability         Boolean  @default(false)
  adjustedAmount      Float?
  version             Int      @default(1)
  clientRef           String?
  book                Book     @relation(fields: [bookId], references: [id], onDelete: Restrict)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  // ── Core FK lookups ──
  @@index([bookId])
  @@index([linkedTransactionId])
  @@index([chainId])
  @@index([orgFundId])
  @@index([createdById])

  // ── Role-based lookups ──
  @@index([recipientUserId])
  @@index([recipientOrgId])

  // ── Status-based filtering ──
  @@index([reconStatus])
  @@index([pendingAction])

  // ── Composite: book listing (most frequent query) ──
  @@index([bookId, dateTime(sort: Desc)])
  @@index([bookId, reconStatus, dateTime(sort: Desc)])

  // ── Chain queries ──
  @@index([chainId, reconStatus])

  // ── Approval queries ──
  @@index([reconStatus, bookId])
  @@index([reconStatus, createdById])
}

model AudioNote {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  audioUrl   String?
  text       String?
  status     String   @default("pending")
  recordedAt DateTime @default(now())
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([status])
}

model Notification {
  id                   String   @id @default(cuid())
  userId               String
  type                 String
  title                String?
  message              String?
  relatedTransactionId String?
  relatedOrgId         String?
  isRead               Boolean  @default(false)
  isDeleted            Boolean  @default(false)
  createdAt            DateTime @default(now())

  @@index([userId, createdAt(sort: Desc)])
  @@index([userId, isRead])
  @@index([userId, isDeleted])
  @@index([createdAt])
}

model NotificationPreference {
  id                String  @id @default(cuid())
  userId            String
  type              String
  pushEnabled       Boolean @default(true)
  emailEnabled      Boolean @default(true)
  inAppEnabled      Boolean @default(true)

  @@unique([userId, type])
  @@index([userId])
}

model FcmToken {
  id        String   @id @default(cuid())
  userId    String
  token     String
  deviceInfo String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([token])
  @@index([userId])
}

model Category {
  id          String   @id @default(cuid())
  userId      String?
  name        String
  type        String   // INCOME or EXPENSE
  isPermanent Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([userId])
}
