generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String               @id @default(cuid())
  name         String
  email        String?              @unique
  phoneNumber  String?
  password     String
  tokenVersion Int                  @default(0)
  avatarUrl    String?
  isAdmin      Boolean              @default(false)
  aiConfig     Json?
  aiChatMessages AiChatMessage[]
  memberships  OrganizationMember[]
  complaints   Complaint[]
  audioNotes   AudioNote[]
  createdAt    DateTime             @default(now())
}

model AiChatMessage {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      String
  content   String
  bookId    String?
  model     String?
  provider  String?
  intent    String?
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

model Complaint {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  subject    String
  message    String
  status     String   @default("open")
  priority   String   @default("medium")
  category   String?
  assignedTo String?
  response   String?
  imageUrls  String[]
  videoUrls  String[]
  createdAt  DateTime @default(now())
}

model Organization {
  id                String               @id @default(cuid())
  name              String
  isPersonal        Boolean              @default(false)
  inviteCode        String?              @unique
  imageUrl          String?
  categories        String[]
  approvalPolicy    String               @default("GLOBALLY_ON")
  whitelistedUserIds String[]
  members           OrganizationMember[]
  books             Book[]
  createdAt         DateTime             @default(now())
}

model OrganizationMember {
  id             String       @id @default(cuid())
  userId         String
  organizationId String
  role           String       @default("member")
  status         String       @default("pending")
  permissions    String[]
  user           User         @relation(fields: [userId], references: [id])
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdAt      DateTime     @default(now())

  @@unique([userId, organizationId])
}

model Book {
  id             String       @id @default(cuid())
  name           String
  isDefault      Boolean      @default(false)
  balance        Float        @default(0)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  transactions   Transaction[]
  createdAt      DateTime     @default(now())
}

model Transaction {
  id                  String   @id @default(cuid())
  bookId              String
  amount              Float
  type                String
  note                String?
  category            String?
  contact             String?
  recipientUserId     String?
  recipientOrgId      String?
  linkedTransactionId String?
  orgFundId           String?
  imageUrl            String?
  reconStatus         String   @default("approved")
  pendingAction       String?
  pendingData         Json?
  updateHistory       Json[]
  dateTime            DateTime @default(now())
  status              String?
  createdById         String?
  counterProposedAmount Float?
  counterProposedBy     String?
  chainId             String?
  chainType           String?
  isLiability         Boolean  @default(false)
  adjustedAmount      Float?
  version             Int      @default(1)
  clientRef           String?
  book                Book     @relation(fields: [bookId], references: [id])
  createdAt           DateTime @default(now())
}

model AudioNote {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  audioUrl   String?  // the URL or path to the saved audio file
  text       String?  // transcribed text
  status     String   @default("pending") // pending, processed, error
  recordedAt DateTime @default(now()) // When the user actually recorded it offline
  createdAt  DateTime @default(now()) // When it was synced to server
}
