PORT=8000
DATABASE_URL="postgresql://user:password@host:5432/hisabpata?schema=public"
JWT_SECRET="your-strong-random-secret-here"
NODE_ENV=production
CORS_ORIGINS="https://hisabpata.shilpigosthi.com,http://localhost:3001,http://localhost:8080"
# SEED_DEFAULT_USER="true"   # uncomment to auto-create default user on first run

# Object storage (SaimumFile / SeaweedFS S3 / MinIO / Cloudflare R2). Leave AWS_ENDPOINT_URL empty to use local uploads/ folder.
# AWS_ENDPOINT_URL="https://your-s3-endpoint"
# AWS_BUCKET="hisabpata"
# AWS_ACCESS_KEY_ID="your-access-key"
# AWS_SECRET_ACCESS_KEY="your-secret-key"
# AWS_REGION="us-east-1"
# AWS_FORCE_PATH_STYLE="true"

# BanglaSpeechAPI (Bengali voice → text for AI chat & quick notes)
# Deploy BanglaSpeechAPI/ — copy VALID_API_KEYS value into ASR_API_KEY here.
# ASR_BASE_URL="https://stotext.shilpigosthi.com"
# ASR_API_KEY="your_bangla_speech_api_key"

# AI server (Gemma 3 1B IT via llama.cpp + router)
# Coolify internal URL: http://hisab-ai-router:5328
AI_SERVER_URL="http://localhost:5328"
